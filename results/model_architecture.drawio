<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Title -->
    <mxCell id="title" value="Probabilistic GRU for Coastal Heat-Stress Forecasting" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#1a1a1a;" vertex="1" parent="1">
      <mxGeometry x="100" y="10" width="600" height="30" as="geometry"/>
    </mxCell>

    <!-- Input Block -->
    <mxCell id="input" value="&lt;b&gt;Input&lt;/b&gt;&lt;br&gt;X ∈ ℝ&lt;sup&gt;B×72×24&lt;/sup&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#666&quot;&gt;72h lookback, 24 features&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F4FF;strokeColor=#4A6FA5;strokeWidth=1.5;fontSize=11;arcSize=12;" vertex="1" parent="1">
      <mxGeometry x="40" y="60" width="140" height="70" as="geometry"/>
    </mxCell>

    <!-- Feature Projection -->
    <mxCell id="feat_proj" value="&lt;b&gt;Feature Projection&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Linear(24→64)&lt;br&gt;LayerNorm → GELU → Dropout(0.2)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;strokeWidth=1.5;fontSize=11;arcSize=12;" vertex="1" parent="1">
      <mxGeometry x="220" y="60" width="180" height="70" as="geometry"/>
    </mxCell>

    <!-- Arrow: Input → Feature Projection -->
    <mxCell id="arr1" style="endArrow=classic;strokeColor=#555;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="input" target="feat_proj">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- GRU Encoder -->
    <mxCell id="gru" value="&lt;b&gt;GRU Encoder&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;2-layer, hidden=128&lt;br&gt;batch_first=True&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;strokeWidth=1.5;fontSize=11;arcSize=12;" vertex="1" parent="1">
      <mxGeometry x="440" y="60" width="160" height="70" as="geometry"/>
    </mxCell>

    <!-- Arrow: Feature Projection → GRU -->
    <mxCell id="arr2" style="endArrow=classic;strokeColor=#555;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="feat_proj" target="gru">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- GRU output labels -->
    <mxCell id="gru_out_label1" value="&lt;font style=&quot;font-size:9px;color:#1976D2&quot;&gt;encoder_outputs&lt;br&gt;[B, 72, 128]&lt;/font&gt;" style="text;html=1;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
      <mxGeometry x="620" y="52" width="110" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="gru_out_label2" value="&lt;font style=&quot;font-size:9px;color:#1976D2&quot;&gt;last hidden h&lt;sub&gt;T&lt;/sub&gt;&lt;br&gt;[B, 128]&lt;/font&gt;" style="text;html=1;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
      <mxGeometry x="620" y="87" width="110" height="35" as="geometry"/>
    </mxCell>

    <!-- Arrow: GRU → labels area (split) -->
    <mxCell id="arr3a" style="endArrow=classic;strokeColor=#1976D2;strokeWidth=1.2;exitX=1;exitY=0.35;exitDx=0;exitDy=0;dashed=0;" edge="1" parent="1" source="gru">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="620" y="70" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="arr3b" style="endArrow=classic;strokeColor=#1976D2;strokeWidth=1.2;exitX=1;exitY=0.65;exitDx=0;exitDy=0;dashed=0;" edge="1" parent="1" source="gru">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="620" y="105" as="targetPoint"/>
      </mxGeometry>
    </mxCell>

    <!-- Last Hidden State (query) going down -->
    <mxCell id="last_h" value="&lt;b&gt;h&lt;sub&gt;T&lt;/sub&gt;&lt;/b&gt; (Query)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#F57C00;strokeWidth=1.5;fontSize=10;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="340" y="175" width="100" height="40" as="geometry"/>
    </mxCell>

    <!-- Arrow: GRU → last_h (down) -->
    <mxCell id="arr_h" style="endArrow=classic;strokeColor=#F57C00;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;curved=1;" edge="1" parent="1" source="gru" target="last_h">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Encoder Outputs (K, V) going down -->
    <mxCell id="enc_out" value="&lt;b&gt;Encoder Outputs&lt;/b&gt;&lt;br&gt;(Key, Value)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#F57C00;strokeWidth=1.5;fontSize=10;arcSize=20;" vertex="1" parent="1">
      <mxGeometry x="470" y="175" width="130" height="40" as="geometry"/>
    </mxCell>

    <!-- Arrow: GRU → enc_out -->
    <mxCell id="arr_enc" style="endArrow=classic;strokeColor=#F57C00;strokeWidth=1.5;exitX=0.7;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="gru" target="enc_out">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Multi-Head Attention (optional) -->
    <mxCell id="mha" value="&lt;b&gt;Multi-Head Attention&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;4 heads, dropout=0.2&lt;br&gt;Q=h&lt;sub&gt;T&lt;/sub&gt;, K=V=encoder_out&lt;br&gt;&lt;i&gt;(ablation: optional)&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;strokeWidth=1.5;fontSize=11;arcSize=12;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
      <mxGeometry x="340" y="245" width="260" height="65" as="geometry"/>
    </mxCell>

    <!-- Arrows into MHA -->
    <mxCell id="arr_q" style="endArrow=classic;strokeColor=#F57C00;strokeWidth=1.2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="last_h" target="mha">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="arr_kv" style="endArrow=classic;strokeColor=#F57C00;strokeWidth=1.2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="enc_out" target="mha">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Concat + LayerNorm -->
    <mxCell id="concat" value="&lt;b&gt;Concat &amp; LayerNorm&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[h&lt;sub&gt;T&lt;/sub&gt; ; attn_context] → [B, 256]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=1.5;fontSize=11;arcSize=12;" vertex="1" parent="1">
      <mxGeometry x="340" y="340" width="260" height="50" as="geometry"/>
    </mxCell>

    <!-- Arrow: MHA → Concat -->
    <mxCell id="arr_mha_concat" style="endArrow=classic;strokeColor=#555;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="mha" target="concat">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Also h_T skip connection to concat -->
    <mxCell id="arr_skip_h" value="" style="endArrow=classic;strokeColor=#F57C00;strokeWidth=1.2;dashed=1;dashPattern=5 3;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;curved=1;" edge="1" parent="1" source="last_h" target="concat">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="310" y="250"/>
          <mxPoint x="310" y="365"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="skip_label" value="&lt;font style=&quot;font-size:8px;color:#F57C00&quot;&gt;skip&lt;/font&gt;" style="text;html=1;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
      <mxGeometry x="290" y="285" width="30" height="15" as="geometry"/>
    </mxCell>

    <!-- Horizon Embedding -->
    <mxCell id="horizon_emb" value="&lt;b&gt;Horizon Embedding&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;nn.Embedding(24, 128)&lt;br&gt;&lt;i&gt;(ablation: optional)&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;strokeWidth=1.5;fontSize=11;arcSize=12;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
      <mxGeometry x="60" y="340" width="180" height="55" as="geometry"/>
    </mxCell>

    <!-- Horizon IDs input -->
    <mxCell id="horizon_ids" value="&lt;font style=&quot;font-size:9px;color:#666&quot;&gt;horizon_ids&lt;br&gt;[0, 1, …, 23]&lt;/font&gt;" style="text;html=1;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
      <mxGeometry x="80" y="300" width="120" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="arr_hids" style="endArrow=classic;strokeColor=#F9A825;strokeWidth=1.2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="horizon_ids" target="horizon_emb">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Repeat + Cat -->
    <mxCell id="repeat_cat" value="&lt;b&gt;Repeat(×24) &amp; Cat&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[B, 24, 256+128] → [B, 24, 384]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;strokeWidth=1.5;fontSize=11;arcSize=12;" vertex="1" parent="1">
      <mxGeometry x="150" y="430" width="250" height="50" as="geometry"/>
    </mxCell>

    <!-- Arrow: Concat → Repeat -->
    <mxCell id="arr_c_r" style="endArrow=classic;strokeColor=#555;strokeWidth=1.5;exitX=0.3;exitY=1;exitDx=0;exitDy=0;entryX=0.6;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="concat" target="repeat_cat">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Arrow: Horizon Emb → Repeat -->
    <mxCell id="arr_he_r" style="endArrow=classic;strokeColor=#F9A825;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.2;entryY=0;entryDx=0;entryDy=0;curved=1;" edge="1" parent="1" source="horizon_emb" target="repeat_cat">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Residual Decoder -->
    <mxCell id="res_dec" value="&lt;b&gt;Residual Decoder&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Linear(384→128)&lt;br&gt;Block 1: Linear→GELU→Dropout + Residual + LN&lt;br&gt;Block 2: Linear→GELU→Dropout + Residual + LN&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F7FA;strokeColor=#00838F;strokeWidth=1.5;fontSize=11;arcSize=12;" vertex="1" parent="1">
      <mxGeometry x="150" y="510" width="310" height="70" as="geometry"/>
    </mxCell>

    <!-- Arrow: Repeat → Decoder -->
    <mxCell id="arr_r_d" style="endArrow=classic;strokeColor=#555;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="repeat_cat" target="res_dec">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Mean Head -->
    <mxCell id="mean_head" value="&lt;b&gt;Mean Head&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Linear(128→2)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=1.5;fontSize=11;arcSize=12;" vertex="1" parent="1">
      <mxGeometry x="520" y="510" width="120" height="45" as="geometry"/>
    </mxCell>

    <!-- LogVar Head -->
    <mxCell id="logvar_head" value="&lt;b&gt;LogVar Head&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Linear(128→2)&lt;br&gt;clamp [−8, 6]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=1.5;fontSize=11;arcSize=12;" vertex="1" parent="1">
      <mxGeometry x="660" y="510" width="120" height="45" as="geometry"/>
    </mxCell>

    <!-- Arrows: Decoder → Heads -->
    <mxCell id="arr_d_m" style="endArrow=classic;strokeColor=#2E7D32;strokeWidth=1.5;exitX=1;exitY=0.35;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="res_dec" target="mean_head">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="arr_d_v" style="endArrow=classic;strokeColor=#E65100;strokeWidth=1.5;exitX=1;exitY=0.65;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="res_dec" target="logvar_head">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Output: μ -->
    <mxCell id="out_mean" value="&lt;b&gt;μ&lt;/b&gt; ∈ ℝ&lt;sup&gt;B×24×2&lt;/sup&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontSize=12;arcSize=20;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="530" y="580" width="100" height="35" as="geometry"/>
    </mxCell>

    <!-- Output: log σ² -->
    <mxCell id="out_logvar" value="&lt;b&gt;log σ²&lt;/b&gt; ∈ ℝ&lt;sup&gt;B×24×2&lt;/sup&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;fontSize=12;arcSize=20;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="665" y="580" width="110" height="35" as="geometry"/>
    </mxCell>

    <!-- Arrows: Heads → Outputs -->
    <mxCell id="arr_m_o" style="endArrow=classic;strokeColor=#2E7D32;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="mean_head" target="out_mean">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="arr_v_o" style="endArrow=classic;strokeColor=#E65100;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="logvar_head" target="out_logvar">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Target labels -->
    <mxCell id="target_label" value="&lt;font style=&quot;font-size:9px;color:#555&quot;&gt;Targets: [Heat Index, WBGT-like]&lt;/font&gt;" style="text;html=1;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
      <mxGeometry x="570" y="618" width="180" height="20" as="geometry"/>
    </mxCell>

    <!-- Loss function annotation -->
    <mxCell id="loss_box" value="&lt;b&gt;Loss Function&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;ℒ = Σ w&lt;sub&gt;h&lt;/sub&gt; · NLL(μ, σ², y) + 0.1·MSE + 10⁻⁴·Var penalty&lt;br&gt;w&lt;sub&gt;h&lt;/sub&gt;: linearly 1.0 (h=1) → 2.0 (h=24)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#9E9E9E;strokeWidth=1;fontSize=11;arcSize=8;dashed=1;dashPattern=5 3;" vertex="1" parent="1">
      <mxGeometry x="40" y="570" width="280" height="55" as="geometry"/>
    </mxCell>

    <!-- MC Dropout annotation -->
    <mxCell id="mc_box" value="&lt;b&gt;Inference: MC Dropout&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;30 forward passes → epistemic uncertainty&lt;br&gt;σ²&lt;sub&gt;total&lt;/sub&gt; = σ²&lt;sub&gt;aleatoric&lt;/sub&gt; + σ²&lt;sub&gt;epistemic&lt;/sub&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#9E9E9E;strokeWidth=1;fontSize=11;arcSize=8;dashed=1;dashPattern=5 3;" vertex="1" parent="1">
      <mxGeometry x="40" y="500" width="100" height="60" as="geometry"/>
    </mxCell>

    <!-- Param count -->
    <mxCell id="param_note" value="&lt;font style=&quot;font-size:9px;color:#888&quot;&gt;~328K trainable parameters&lt;/font&gt;" style="text;html=1;align=right;fillColor=none;strokeColor=none;" vertex="1" parent="1">
      <mxGeometry x="600" y="635" width="180" height="20" as="geometry"/>
    </mxCell>

    <!-- Dashed group boxes for encoder / decoder sections -->
    <mxCell id="enc_group_label" value="&lt;font style=&quot;font-size:10px;color:#1976D2;fontStyle=1&quot;&gt;ENCODER&lt;/font&gt;" style="text;html=1;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
      <mxGeometry x="45" y="45" width="80" height="15" as="geometry"/>
    </mxCell>
    <mxCell id="dec_group_label" value="&lt;font style=&quot;font-size:10px;color=#00838F;fontStyle=1&quot;&gt;DECODER&lt;/font&gt;" style="text;html=1;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
      <mxGeometry x="155" y="415" width="80" height="15" as="geometry"/>
    </mxCell>
    <mxCell id="attn_group_label" value="&lt;font style=&quot;font-size:10px;color:#C62828;fontStyle=1&quot;&gt;ATTENTION (optional)&lt;/font&gt;" style="text;html=1;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
      <mxGeometry x="345" y="160" width="150" height="15" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>